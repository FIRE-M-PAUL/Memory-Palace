# =============================================================================
# MEMORY PALACE — Environment variables (all optional for MVP demo deploy)
# =============================================================================
# Copy to .env.local for local development. On Vercel, add these in Project Settings.

# --- OpenAI (optional — app uses local engine when missing) ---
# OPENAI_API_KEY=sk-your-openai-key

# --- Supabase (optional — app uses localStorage when missing) ---
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Upload limits (optional) ---
# Vercel serverless body limit is ~4.5MB — keep at 4 for production deploys.
# MAX_UPLOAD_MB=4
# NEXT_PUBLIC_MAX_UPLOAD_MB=4
# For local dev with larger files: MAX_UPLOAD_MB=15
